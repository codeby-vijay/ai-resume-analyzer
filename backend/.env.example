APP_NAME=AI Resume Analyzer
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-64-char-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

